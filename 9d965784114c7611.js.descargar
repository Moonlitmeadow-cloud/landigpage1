        ... on CustomerSalesContract {
          id
          name
          isTrial
          startDate
          endDate
          salesContactEmail
        }
        ... on CustomerFreeTier {
          _empty
        }
      }
      paymentMethod {
        id
        last4
        expirationMonth
        expirationYear
        externalId
        isSaved
      }
    }
  }
}
