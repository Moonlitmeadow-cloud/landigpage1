    fragment UsageIntervalFields on CustomerUsageInterval {
  startDate
  endDate
  orgUsage(orgId: $orgId) {
    __typename
    ... on CustomerOrgUsage {
      totalAmountUsd
      agentUsageByUser {
        items {
          userId
          amountUsd
          email
          orgRole
          user {
            id
            displayName
            username
            image
          }
        }
      }
    }
    ... on UnauthorizedError {
      message
    }
  }
}
    `,r8=s.gql`
    query WorkspaceUsage($orgId: String, $hasOrgId: Boolean!) {
  getOrg(orgId: $orgId) @include(if: $hasOrgId) {
    __typename
    ... on Org {
      id
      customer {
        __typename
        ... on Customer {
          id
          usageInterval {
            ...UsageIntervalFields
          }
        }
        ... on UnauthorizedError {
          message
        }
        ... on NotFoundError {
          message
        }
      }
      usageBasedBillingAlerts {
        ... on UsageBasedBillingAlertsConfig {
          ...OrgUsageBillingAlertsConfig
        }
        ... on Error {
          message
        }
      }
      authorizations {
        viewUsageAlerts {
          isAuthorized
          message
        }
        editUsageAlerts {
          isAuthorized
          message
        }
      }
    }
  }
  currentUser @skip(if: $hasOrgId) {
    __typename
    id
    ... on CurrentUser {
      customer {
        id
        usageInterval {
          ...UsageIntervalFields
        }
      }
    }
  }
}
