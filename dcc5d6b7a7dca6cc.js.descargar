    __typename
    ... on ScheduledJobListExecutionsResults {
      results {
        id
        startedAt
        endedAt
        status
      }
    }
    ... on UnauthorizedError {
      message
    }
    ... on NotFoundError {
      message
    }
    ... on UserError {
      message
    }
    ... on Error {
      message
    }
  }
}
