      echo "$remote_result" | \\
      head -1 | \\
      awk '{print $2}' | \\
      sed -e "s/^refs\\/heads\\///"
    )"
    git remote set-head "$remote" "$branch_name" >&2
    echo "$branch_name"
  fi
fi
`.trim()})"
  if [ -z "$branch" ]; then continue; fi
  echo "refs/remotes/$remote/$branch"
  if [ $(git rev-parse --verify --quiet "heads/$branch") ]; then
    echo "refs/heads/$branch"
  fi
done
