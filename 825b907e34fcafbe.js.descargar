    mutation RecordTipInteraction($tipId: String!, $interactionType: TipInteractionType!, $interactionContext: String, $recommendedReason: String) {
  recordTipInteraction(
    tipId: $tipId
    interactionType: $interactionType
    interactionContext: $interactionContext
    recommendedReason: $recommendedReason
  ) {
    __typename
    ... on RecordTipInteractionResult {
      tipState {
        id
        title
        description
        content
        tags
        priority
        timeRecommended
        timeCompleted
        timeDismissed
        timeInteracted
        externalUrl
