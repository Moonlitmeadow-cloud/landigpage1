        message
        code
      }
      ... on Error {
        message
      }
    }
    defaultAdvancedAgentModelAuthorization(replId: $replId) {
      ... on OrgAuthorization {
        isAuthorized
        message
        code
      }
      ... on Error {
        message
      }
    }
  }
}
